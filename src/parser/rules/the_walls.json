{
  "id": "the_walls",
  "name": "Global The Walls",
  "description": "Game-state and result signal rules for the_walls.",
  "cleaners": [
    {
      "pattern": "^\\[(?!(?:起床战争|空岛战争|天空之战|超级战墙|迷你战墙|UHC|IRC)\\])[^\\]]+\\]\\s*",
      "replacement": ""
    },
    {
      "pattern": "^(?:\\[(?!(?:UHC|IRC)\\])[A-Z]+\\]\\s*)+",
      "flags": "i",
      "replacement": ""
    },
    {
      "pattern": "^(?:花雨庭\\s*)?>>\\s*",
      "replacement": ""
    }
  ],
  "rules": [
    {
      "id": "the_walls_mode",
      "type": "game_mode",
      "pattern": "^The Walls\\s*$",
      "flags": "i",
      "payload": {
        "gameMode": "the_walls"
      },
      "legacyRuleSet": "game-state",
      "matchOrder": 79
    },
    {
      "id": "zh_the_walls_mode",
      "type": "game_mode",
      "pattern": "^(?:战墙|\\[战墙\\]\\s*>?.*)$",
      "cleaners": [],
      "payload": {
        "gameMode": "the_walls"
      },
      "legacyRuleSet": "game-state",
      "matchOrder": 79.1
    }
  ]
}
