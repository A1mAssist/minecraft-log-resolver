{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Minecraft Log Observatory",
  "version": "0.3.0",
  "identifier": "app.minecraft-log-observatory.local",
  "build": {
    "frontendDist": "../dist/tauri-frontend",
    "beforeDevCommand": "npm.cmd run build:tauri-frontend",
    "beforeBuildCommand": "npm.cmd run build:tauri-frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Minecraft Log Observatory",
        "width": 1280,
        "height": 820,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
